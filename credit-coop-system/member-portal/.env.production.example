# Member Portal - Production Environment Variables
# These variables are embedded into the React build at compile time

# API Base URL - The backend server URL
REACT_APP_API_URL=https://members.yourdomain.com

# Socket.IO Server URL (for real-time notifications)
REACT_APP_SOCKET_URL=https://members.yourdomain.com

# PayMongo Public Key (for client-side payment processing)
REACT_APP_PAYMONGO_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY_HERE

# Environment
NODE_ENV=production
