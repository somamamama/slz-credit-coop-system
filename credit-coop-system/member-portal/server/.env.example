# Example environment variables for local development.
# Copy this file to .env and fill in real values. DO NOT commit your .env with secrets.

# PayMongo secret key (test key example). Get from https://dashboard.paymongo.com -> Developers -> API keys
PAYMONGO_SECRET_KEY=sk_test_your_test_key_here

# Optional fallback test key name supported by the server
PAYMONGO_TEST_KEY=sk_test_your_fallback_key_here

# Client origin used when building redirect URLs (optional)
CLIENT_ORIGIN=http://localhost:3000

# JWT secret used for local dev only (change in production)
jwtSecret=change_me_development

# Optional webhook secret for verifying PayMongo webhook signatures
# Get this from the PayMongo dashboard when creating a webhook (recommended for production)
PAYMONGO_WEBHOOK_SECRET=whsec_your_webhook_secret_here
