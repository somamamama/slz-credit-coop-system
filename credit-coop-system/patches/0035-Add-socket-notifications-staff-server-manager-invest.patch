index 0000000..13ef391
--- /dev/null
+++ b/staff-portal/server/test-socket.html
@@ -0,0 +1,37 @@
+<!doctype html>
+<html>
+<head>
+  <meta charset="utf-8" />
+  <title>Socket Test - Manager</title>
+  <style>body{font-family:Arial,sans-serif;padding:12px} #log{white-space:pre-wrap;background:#f7f7f7;padding:12px;border-radius:6px;min-height:120px}</style>
+</head>
+<body>
+  <h2>Socket Test Page</h2>
+  <p>This page connects to the staff socket server and joins the <code>manager</code> room. Use this to verify connectivity independent of the React frontend.</p>
+  <div><button id="emitNotify">Send test notify (POST /api/notify/new-application)</button></div>
+  <h3>Socket status: <span id="status">(not connected)</span></h3>
+  <div id="log"></div>
+  <script src="/socket.io/socket.io.js"></script>
+  <script>
+    (function(){
+      function log(m){
+        var el = document.getElementById('log');
+        el.textContent = (new Date()).toLocaleTimeString() + ' - ' + m + '\n' + el.textContent;
+      }
+      try{
+        var socket = io();
+        document.getElementById('status').textContent = 'connecting...';
+        socket.on('connect', function(){ document.getElementById('status').textContent = 'connected ('+socket.id+')'; log('connected '+socket.id); try{ socket.emit('join',{role:'manager'}); log('emitted join manager'); }catch(e){ log('emit join failed: '+e); } });
+        socket.on('connect_error', function(err){ document.getElementById('status').textContent = 'connect_error'; log('connect_error '+err); });
