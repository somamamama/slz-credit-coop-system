index 0204b2f..2731565 100644
--- a/member-portal/server/index.js
+++ b/member-portal/server/index.js
@@ -1,26 +1,24 @@
 // Load environment variables from .env when present (development convenience)
 // This allows the server to pick up `jwtSecret`, `PAYMONGO_SECRET_KEY`, etc.
-      SELECT
-        application_id,
-        user_id,
-        member_number,
-        loan_type,
-        membership_type,
-        first_name,
