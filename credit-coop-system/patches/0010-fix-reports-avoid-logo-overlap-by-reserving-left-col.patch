From 94d287019f53215e66778132dfab256c3e098322 Mon Sep 17 00:00:00 2001
From: somamamama <22-06543@g.batstate-u.edu.ph>
Date: Sun, 23 Nov 2025 10:33:40 +0800
Subject: [PATCH 10/37] fix(reports): avoid logo overlap by reserving left
 column and starting content after logo

---
 staff-portal/src/pages/Reports.js | 29 ++++++++++++++++-------------
 1 file changed, 16 insertions(+), 13 deletions(-)

diff --git a/staff-portal/src/pages/Reports.js b/staff-portal/src/pages/Reports.js
index f92048f..efbba35 100644
--- a/staff-portal/src/pages/Reports.js
+++ b/staff-portal/src/pages/Reports.js
@@ -144,19 +144,22 @@ const Reports = () => {
         }
       }
 
-      // draw logo left if available
+      // draw logo left if available and reserve content start X
+      const logoW = 56;
+      const logoH = 56;
       if (finalLogo) {
         try {
-          // choose image type automatically (png/jpg) by data URL
-          doc.addImage(finalLogo, 'PNG', margin, 36, 56, 56);
+          // try PNG first
+          doc.addImage(finalLogo, 'PNG', margin, 36, logoW, logoH);
         } catch (e) {
           try {
-            doc.addImage(finalLogo, 'JPEG', margin, 36, 56, 56);
+            doc.addImage(finalLogo, 'JPEG', margin, 36, logoW, logoH);
           } catch (er) {
             console.warn('addImage failed for logo', er);
           }
         }
       }
+      const contentStartX = finalLogo ? margin + logoW + 12 : margin;
 
       // header text
       doc.setFontSize(14);
@@ -171,9 +174,9 @@ const Reports = () => {
       const genWidth = doc.getTextWidth(generatedText);
       doc.text(generatedText, rightX - genWidth, y);
 
-      y += 18;
-      doc.setFontSize(10);
-      doc.text(`Period: ${from} — ${to}`, margin, y);
+  y += 18;
+  doc.setFontSize(10);
+  doc.text(`Period: ${from} — ${to}`, contentStartX, y);
       y += 18;
 
       // compute summary stats for financial report
@@ -189,8 +192,8 @@ const Reports = () => {
         stats = { members: data.rows.length };
       }
 
-      // draw small stat boxes
-      const statX = margin;
+  // draw small stat boxes
+  const statX = contentStartX;
       let statY = y;
       doc.setFontSize(9);
       if (reportType === 'financial') {
@@ -226,10 +229,10 @@ const Reports = () => {
 
   // draw headers
   const colX = [];
-  const usableWidth = pageWidth - margin * 2;
-      const headers = data.headers;
-      const colWidth = usableWidth / headers.length;
-      headers.forEach((h, i) => colX.push(margin + i * colWidth));
+  const usableWidth = pageWidth - contentStartX - margin;
+    const headers = data.headers;
+    const colWidth = usableWidth / headers.length;
+    headers.forEach((h, i) => colX.push(contentStartX + i * colWidth));
 
       doc.setFontSize(9);
       doc.setFillColor(245, 245, 250);
-- 
