Subject: [PATCH 36/37] landing-page: place membership info icon beside select
 and adjust styles

---
 .../src/components/MembershipApplication.css  | 77 +++++++++++++++++++
 .../src/components/MembershipApplication.js   | 34 +++++---
 2 files changed, 101 insertions(+), 10 deletions(-)

diff --git a/landing-page/src/components/MembershipApplication.css b/landing-page/src/components/MembershipApplication.css
index 595fdc8..423ec78 100644
--- a/landing-page/src/components/MembershipApplication.css
+++ b/landing-page/src/components/MembershipApplication.css
@@ -109,6 +109,83 @@
   font-weight: 500;
 }
 
+/* Info icon and tooltip for small contextual help */
+.info-icon {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: 18px;
+  height: 18px;
+  margin-left: 8px;
+  background: var(--gray-100);
+  color: var(--primary-purple);
+  border-radius: 50%;
+  font-size: 12px;
+  font-weight: 700;
+  line-height: 1;
+  cursor: default;
+  position: relative;
+}
+
+.info-icon:focus {
+  outline: none;
+  box-shadow: 0 0 0 3px rgba(139,92,246,0.12);
+}
+
+.info-icon .tooltip {
+  position: absolute;
+  top: 28px;
+  left: 50%;
+  transform: translateX(-50%);
+  min-width: 220px;
+  max-width: 320px;
+  background: var(--white);
+  border: 1px solid var(--gray-200);
+  color: var(--gray-800);
+  padding: 0.6rem 0.75rem;
+  border-radius: 6px;
+  box-shadow: 0 6px 18px rgba(16,24,40,0.08);
+  font-size: 0.85rem;
+  line-height: 1.3;
+  z-index: 40;
+  opacity: 0;
+  visibility: hidden;
+  transition: opacity 0.12s ease, transform 0.12s ease;
+  transform-origin: top center;
+}
+
+/* Place the info icon beside the select (drop bar) - icon sits outside the control */
+.select-with-info {
+  display: flex;
+  align-items: center;
+  gap: 0.5rem;
+  width: 100%;
+}
+
+.select-with-info select {
+  flex: 1;
+  padding-right: 0; /* no extra inset, icon is outside */
+}
+
+.select-with-info .info-icon {
+  position: relative;
+  margin-left: 0;
+  flex: 0 0 auto;
+  width: 20px;
+  height: 20px;
+  font-size: 12px;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+}
+
+.info-icon:hover .tooltip,
+.info-icon:focus .tooltip {
+  opacity: 1;
+  visibility: visible;
+  transform: translateX(-50%) translateY(2px);
+}
+
 .form-group input,
 .form-group select {
   width: 100%;
